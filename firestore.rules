rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function isApproved() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && getProfile().approved == true;
    }

    function isAdmin() {
      return isApproved() && getProfile().role == 'admin';
    }

    function canWrite() {
      return isApproved() && getProfile().role in ['staff', 'researcher', 'admin'];
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    // Read-only for approved users
    match /map_experience_config/{doc} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /plot_basemaps/{doc} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /plots/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /species/{doc} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /trees/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /growth_logs/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /growth_dbh/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /growth_bamboo/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /growth_banana/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /plot_images/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /plot_spacing/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /import_jobs/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /comments/{doc} {
      allow read: if isApproved();
      allow write: if canWrite();
    }

    match /notifications/{doc} {
      allow read: if isSignedIn()
                  && (resource.data.userId == request.auth.uid
                      || resource.data.user_id == request.auth.uid);
      allow write: if canWrite();
    }
  }
}
