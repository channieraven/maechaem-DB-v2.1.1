rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Get current user's profile
    function getUserProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function isApproved() {
      return request.auth != null
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && getUserProfile().data.approved == true;
    }

    function isWriter() {
      return isApproved() && getUserProfile().data.role in ['staff', 'researcher', 'admin'];
    }

    function isAdmin() {
      return isApproved() && getUserProfile().data.role == 'admin';
    }

    // profiles: owner read/update, admin read all
    match /profiles/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
      // Allow create for own profile with any role/approved status
      // Application logic handles first user = admin + approved
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.auth.uid == request.resource.data.id
                    && request.resource.data.email is string
                    && request.resource.data.fullname is string;
    }

    // plots: approved users read, writers write
    match /plots/{plotId} {
      allow read: if isApproved();
      allow write: if isWriter();
    }

    // trees: approved users read, writers write
    match /trees/{treeId} {
      allow read: if isApproved();
      allow write: if isWriter();
    }

    // growth_logs: approved users read, writers write
    match /growth_logs/{logId} {
      allow read: if isApproved();
      allow write: if isWriter();
    }

    // plot_images: approved users read, writers write/delete
    match /plot_images/{imageId} {
      allow read: if isApproved();
      allow write: if isWriter();
      allow delete: if isWriter();
    }

    // species: authenticated users read, admin write
    match /species/{speciesId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
